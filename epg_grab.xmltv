    <category lang="sl">Poljudnoznanstvena oddaja</category>
    <icon src="https://vimg.siol.tv/sioltv/epg/999/DAVINCILEAR/20/8/3/835022.jpg" />
    <star-rating>
      <value>8.7/10</value>
    </star-rating>
  </programme>
  <programme start="20201004030000 +0200" stop="20201004033000 +0200" channel="davincilear">
    <title lang="sl">Raziskujmo: Čudoviti planet: Kulturologija</title>
    <sub-title lang="sl">Xploration: Awesome Planet: Cultural Science</sub-title>
    <desc lang="sl">Tokrat bo Philippe odveslal na kanuju za šest oseb in proučil starodavno havajsko navigacijo.Na Floridi se bo pridružil plemenu Seminola, ki mu bo pokazalo, kako so rastline v Evergladesu pomembno orodje.</desc>
    <credits>
      <actor>Philippe Cousteau</actor>
