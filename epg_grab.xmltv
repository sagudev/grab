    <title lang="sl">VIP turneja</title>
    <sub-title lang="sl">VIP tour</sub-title>
    <desc lang="sl">Dokumentarna oddaja o svetu ekskluzivnih dosežkov in norih sanj.Jahte, superavtomobili in letala ? od najbolj norih sanj do prestižnih dosežkov. Vip turneja vas popelje v svet izbranega in izjemnega luksuza.</desc>
    <category lang="sl">Dokumentarni</category>
    <category lang="sl">Ostalo</category>
    <icon src="https://vimg.siol.tv/sioltv/epg/999/PLANET2/20/6/6/660408.jpg" />
  </programme>
  <programme start="20201003013800 +0200" stop="20201003075500 +0200" channel="planet2">
