  <programme start="20201004030500 +0200" stop="20201004032500 +0200" channel="cinemax1">
    <title lang="sl">Oče oče</title>
    <sub-title lang="sl">Father Father</sub-title>
    <desc lang="sl">Oče James se mora odločiti, kakšen oče naj bi bil po božji volji.Njegova vloga v življenju morda ni tista, za katero je sprva mislil, da naj bi bila.</desc>
    <category lang="sl">Film</category>
