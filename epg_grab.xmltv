      <actor>Richard Harrison</actor>
      <actor>Austin 'Chumlee' Russell</actor>
      <actor>Mark Hall Patton</actor>
      <actor>Craig Gottlieb</actor>
      <actor>Antwaun Austin</actor>
    </credits>
    <category lang="sl">Razvedrilni</category>
    <category lang="sl">Resničnostna TV</category>
    <icon src="https://vimg.siol.tv/sioltv/epg/999/RTLHRVATSKA2/20/5/0/508224.jpg" />
