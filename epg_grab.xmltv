      <actor>Sergey Leskov</actor>
      <actor>Stanislav Moskvin</actor>
      <actor>Aleksey Zorin</actor>
      <actor>Taras Gotovtsev</actor>
    </credits>
    <category lang="sl">Nadaljevanka</category>
    <category lang="sl">Kriminalka</category>
    <icon src="https://vimg.siol.tv/sioltv/epg/999/PINKSI/20/7/4/742872.jpg" />
