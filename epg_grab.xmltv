  <programme start="20201003110000 +0200" stop="20201003123500 +0200" channel="klasiktv">
    <title lang="sl">Mojstri</title>
    <sub-title lang="sl">Majstori, majstori</sub-title>
    <desc lang="sl">Na dan, ko v pokoj odhaja čistilka šole, prihaja inšpektor, ki je dobil prijavo, da preveri delo namestnika šole.Čistilka na šoli pripravi pojedino in inšpektor ugotovi, da je šola navzven sijajna, znotraj pa je polna nestrpnosti.</desc>
    <credits>
